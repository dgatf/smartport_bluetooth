#:kivy 1.11.1
        
<PopupMonitors@Popup>:
    height: self.ids.rename.font_size * 10
    width: self.ids.rename.font_size * 10
    size_hint: None, None
    title: ''
    separator_height: 0
    GridLayout:
        cols: 1
        Button:
            id: rename
            text: 'Rename'
        Button:
            id: delete
            text: 'Delete'

<PopupAbout@Popup>:
    size_hint: 0.5, 0.5
    title: 'About'
    GridLayout:
        cols: 1
        Label:
            halign: 'center'
            text: 'Smartport BT\nv0.1\nDaniel GeA'
                   
<Toast@Popup>:
    title: 'Error'
    size_hint: 0.5, None
    height: self.ids.label.font_size * 10
    GridLayout:
        cols: 1
        Label:
            id: label

<ButtonList@LongpressButton>:
    size_hint_y: None
    height: self.font_size * 2
    long_press_time: 0.3

<ButtonSensor>:
    markup: True
    halign: 'center'
    sensor_name: 'None'
    sensor_id: 0
    sensor_data_id: 0
    sensor_value: 0
    sensor_index: 0
    sensor_unit: 'no unit'
    text: (self.sensor_name + '\n' + str(self.sensor_value) + ' ' + self.sensor_unit) if self.sensor_data_id else '-'
    font_size: self.height / 3 if 2 * self.height < self.width else self.width / 6
    long_press_time: 0.3

<MyScreenManager>:
    ScreenMonitors:
        id: screen_monitors
        name: 'screen_monitors'
    ScreenMonitor:
        id: screen_monitor
        name: 'screen_monitor'
    ScreenEditName:
        id: screen_edit_name
        name: 'screen_edit_name'
    ScreenEditSensor:
        id: screen_edit_sensor
        name: 'screen_edit_sensor'
    ScreenList:
        id: screen_list
        name: 'screen_list'

<ScreenMonitors>:
    GridLayout:
        cols: 1
        ActionBar:
            pos_hint: {'top':1}
            ActionView:
                use_separator: True
                ActionPrevious:
                    app_icon: 'data/remote.png'
                    title: 'Smartport BT'
                    with_previous: False
                ActionOverflow:
                ActionButton:
                    id: image_connection
                    icon: 'data/circle-red.png'
                    on_release: root.list_bluetooth()
                ActionGroup:
                    text: 'Menu'
                    mode: 'spinner'
                    ActionButton:
                        text: 'Connect'
                        on_release: root.list_bluetooth()
                    ActionButton:
                        text: 'Add monitor'
                        on_release: root.add_monitor()
                    #ActionButton:
                    #    text: 'Settings'
                    ActionButton:
                        text: 'About'
                        on_release: root.show_popup_about()
                    ActionButton:
                        text: 'Exit'
                        on_release: app.get_running_app().stop()
        ScrollView:
            GridLayout:
                id: list_config
                cols: 1
                height: self.minimum_height
                
<ScreenMonitor>:
    GridLayout:
        cols: 1
        ActionBar:
            pos_hint: {'top':1}
            ActionView:
                use_separator: True
                ActionPrevious:
                    id: title
                    app_icon: ''
                    title: 'Smartport BT'
                    with_previous: False
                ActionOverflow:
                ActionButton:
                    text: 'Back'
                    on_release: root.show_screen_monitors()
        GridLayout:
            cols: 2
            ButtonSensor:
                id: sensor1
                index: 'sensor1'
                on_long_press: root.show_screen_edit_sensor(self)
            ButtonSensor:
                id: sensor2
                index: 'sensor2'
                on_long_press: root.show_screen_edit_sensor(self)
            ButtonSensor:
                id: sensor3
                index: 'sensor3'
                on_long_press: root.show_screen_edit_sensor(self)
            ButtonSensor:
                id: sensor4
                index: 'sensor4'
                on_long_press: root.show_screen_edit_sensor(self)
            ButtonSensor:
                id: sensor5
                index: 'sensor5'
                on_long_press: root.show_screen_edit_sensor(self)
            ButtonSensor:
                id: sensor6
                index: 'sensor6'
                on_long_press: root.show_screen_edit_sensor(self)
 
<ScreenEditName>:
    GridLayout:
        cols: 1
        ActionBar:
            pos_hint: {'top':1}
            ActionView:
                use_separator: True
                ActionPrevious:
                    app_icon: ''
                    title: 'Smartport BT'
                    with_previous: False
                ActionOverflow:
                ActionButton:
                    text: 'Ok'
                    on_release: root.update_name()
                ActionButton:
                    text: 'Back'
                    on_release: root.cancel_name()
        GridLayout:
            cols: 1
            Label:
                size_hint_y: None
                height: self.font_size * 2
                text_size: self.size
                text: 'Name'
            TextInput:
                id: text_name
                height: self.font_size * 2
                size_hint_y: None
                multiline: False
                on_text_validate: root.update_name()

<ScreenEditSensor>:
    sensor_id: 0
    sensor_data_id: 0
    sensor_index: 0
    sensor_name: ''
    sensor_unit: ''
    GridLayout:
        cols: 1
        ActionBar:
            pos_hint: {'top':1}
            ActionView:
                use_separator: True
                ActionPrevious:
                    app_icon: ''
                    title: 'Smartport BT'
                    with_previous: False
                ActionOverflow:
                ActionButton:
                    text: 'Ok'
                    on_release: root.update_sensor()
                ActionButton:
                    text: 'Back'
                    on_release: root.show_screen_monitor()
        GridLayout:
            cols: 1
            Label:
                text: 'Sensor name'
                height: self.font_size * 2
                text_size: self.size
                size_hint_y: None
            Button:
                height: self.font_size * 2
                valign: 'center'
                text_size: self.size
                size_hint_y: None
                text: str(root.sensor_name)
                on_release: root.show_sensor_list()    
            Label:
                text: 'Sensor Id'
                height: self.font_size * 2
                text_size: self.size
                size_hint_y: None
            Label:
                height: self.font_size * 2
                text_size: self.size
                text: hex(int(root.sensor_id))
                size_hint_y: None
            Label:
                text: 'Data Id'
                height: self.font_size * 2
                text_size: self.size
                size_hint_y: None
            Label:
                height: self.font_size * 2
                text_size: self.size
                text: hex(int(root.sensor_data_id))
                size_hint_y: None            
            
<ScreenList>:
    GridLayout:
        cols: 1
        ActionBar:
            pos_hint: {'top':1}
            ActionView:
                use_separator: True
                ActionPrevious:
                    id: actionbar
                    app_icon: ''
                    title: 'Smartport BT'
                    with_previous: False
                ActionOverflow:
                ActionButton:
                    text: 'Back'
                    on_release: root.ids.list.clear_widgets(); root.previous_screen()
        ScrollView:
            GridLayout:
                id: list
                cols: 1
                size_hint_y: None
                height: self.minimum_height

